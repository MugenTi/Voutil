import { SettingsWindow } from "./settings_window.slint";
import { MenuIcon, MaximizeIcon, ArrowUpFromLineIcon, 
         FolderIcon, MoveIcon, SquareEqualIcon, SettingsIcon, LogOutIcon,
         CopyIcon, ClipboardPasteIcon,
//         IconSettings
} from "@lucide";

export component AppWindow inherits Window {
    init => {
    //     IconSettings.default-size = 24px;
    }
    title: "Oculante Slint";
    min-width: 640px;
    min-height: 360px;
    preferred-width: 1280px;
    preferred-height: 720px;

    in-out property <image> image_display;
    in-out property <string> status_text: "Ready";
    
    // --- Properties for manual pan and zoom ---
    in-out property <length> image_x: 0px;
    in-out property <length> image_y: 0px;
    in-out property <float> image_scale: 1.0;
    
    // --- Property to control layout mode ---
    in-out property <bool> auto_fit: true;

    // --- Internal state for dragging ---
    private property <bool> _is_dragging: false;
    private property <length> _last_mouse_pos_x: 0px;
    private property <length> _last_mouse_pos_y: 0px;

    // --- Icon properties ---
    private property <brush> _icon_color: #fff;
    private property <length> _icon_size: 24px;

    // Timer for dynamic resize/move handling
    timer := Timer {
        interval: 16ms; // Approx. 60fps
        triggered => {
            root.tick(root.auto_fit);
            self.restart(); // Use restart() to repeat the timer
        }
    }

    function apply_auto_fit_properties() {
        if (root.image_display.width * 1px > 0px && root.image_display.height * 1px > 0px) {
            let image_w = root.image_display.width;
            let image_h = root.image_display.height;

            let container_w = image_container.width;
            let container_h = image_container.height;

            let scale_w = container_w / image_w;
            let scale_h = container_h / image_h;
            let new_scale = min(scale_w, scale_h);

            let new_image_w = image_w * new_scale;
            let new_image_h = image_h * new_scale;

            root.image_scale = new_scale / 1px;
            root.image_x = (container_w - new_image_w) / 2;
            root.image_y = (container_h - new_image_h) / 2;
        }
    }

    function apply_view_one_to_one_properties() {
        let old_scale = root.image_scale;
        let container_w = image_container.width;
        let container_h = image_container.height;

        // Old offset of the image center relative to the container
        let old_center_x = image_x + root.image_display.width * old_scale * 1px / 2;
        let old_center_y = image_y + root.image_display.height * old_scale * 1px / 2;

        // Calculate the new position to keep the center of the image in the center of the container
        let new_image_w = root.image_display.width;
        let new_image_h = root.image_display.height;

        root.image_scale = 1.0;
        root.image_x = (container_w - new_image_w * 1px) / 2;
        root.image_y = (container_h - new_image_h * 1px) / 2;
    }

    VerticalLayout {
        spacing: 0;
        menu_bar := Rectangle {
            height: 30px;
            background: #333;
            HorizontalLayout {
                padding: 5px;
                TouchArea {
                    MenuIcon {
                        colorize: _icon_color;
                        size: _icon_size;
                    }
                    //Text { text: "Menu"; color: white; }
                    clicked => { root.request_open_file(); }
                }

                TouchArea {
                    MaximizeIcon {
                        colorize: _icon_color;
                        size: _icon_size;
                    }
                    //Text { text: "Full Screen"; color: white; }
                    clicked => {  }
                }

                TouchArea {
                    ArrowUpFromLineIcon {
                        colorize: _icon_color;
                        size: _icon_size;
                    }
                    //Text { text: "Always on top"; color: white; }
                    clicked => {  }
                }

                TouchArea {
                    FolderIcon {
                        colorize: _icon_color;
                        size: _icon_size;
                    }
                    //Text { text: "File"; color: white; }
                    clicked => { root.request_open_file(); }
                }

                TouchArea {
                    MoveIcon {
                        colorize: _icon_color;
                        size: _icon_size;
                    }
                    //Text { text: "Reset View"; color: white; }
                    clicked => { root.reset_view(); }
                }
                TouchArea {
                    SquareEqualIcon {
                        colorize: _icon_color;
                        size: _icon_size;
                    } 
                    //Text { text: "1:1"; color: white; }
                    clicked => { 
                        apply_view_one_to_one_properties();
                        root.view_one_to_one();
                    } 
                }
                TouchArea {
                    CopyIcon {
                        colorize: _icon_color;
                        size: _icon_size;
                    }
                    clicked => { root.copy_to_clipboard(); }
                }
                TouchArea {
                    ClipboardPasteIcon {
                        colorize: _icon_color;
                        size: _icon_size;
                    }
                    clicked => { root.paste_from_clipboard(); }
                }
                TouchArea {
                    SettingsIcon {
                        colorize: _icon_color;
                        size: _icon_size;
                    }
                    //Text { text: "menu"; color: white; }
                    clicked => { root.show_settings_window(); }
                }
                
                TouchArea {
                    LogOutIcon {
                        colorize: _icon_color;
                        size: _icon_size;
                    }
                    //Text { text: "Exit"; color: white; }
                    clicked => { root.exit(); }
                }
            }
        }
        image_container := Rectangle {
            background: #333;
            clip: true;
            
            img_element := Image {
                source: root.image_display;
                x: root.auto_fit ? ((parent.width - self.width) / 2) : root.image_x;
                y: root.auto_fit ? ((parent.height - self.height) / 2) : root.image_y;
                width: root.auto_fit ? (min(parent.width, root.image_display.width * 1px)) : (root.image_display.width * root.image_scale * 1px);
                height: root.auto_fit ? (min(parent.height, root.image_display.height * 1px)) : (root.image_display.height * root.image_scale * 1px);

                // keep this code
                // x: root.auto_fit ? 0px : root.image_x;
                // y: root.auto_fit ? 0px : root.image_y;
                // width: root.auto_fit ? parent.width : (root.image_display.width * root.image_scale * 1px);
                // height: root.auto_fit ? parent.height : (root.image_display.height * root.image_scale * 1px);

                image-fit: root.auto_fit ? contain : fill;
            }

            ta := TouchArea {
                pointer-event(event) => {
                    if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                        if (root.auto_fit) {
                            root.auto_fit = false; // Switch to manual mode on drag
                            apply_auto_fit_properties();
                        }
                        _is_dragging = true;
                        _last_mouse_pos_x = ta.mouse-x;
                        _last_mouse_pos_y = ta.mouse-y;
                    } else if (event.kind == PointerEventKind.up && event.button == PointerEventButton.left) {
                        _is_dragging = false;
                    } else if (event.kind == PointerEventKind.move) {
                        if (_is_dragging) {
                            image_x += ta.mouse-x - _last_mouse_pos_x;
                            image_y += ta.mouse-y - _last_mouse_pos_y;
                        }
                        _last_mouse_pos_x = ta.mouse-x;
                        _last_mouse_pos_y = ta.mouse-y;
                    }
                }
                scroll-event(event) => {
                    if (root.auto_fit) {
                        root.auto_fit = false; // Switch to manual mode on zoom
                        apply_auto_fit_properties();
                    }
                    root.zoom_image(event.delta-y / 1px, ta.mouse-x, ta.mouse-y);
                    return accept;
                }
            }
        }
        status_bar := Rectangle {
            height: 25px;
            background: #333;
            HorizontalLayout {
                padding-left: 10px;
                Text {
                    text: root.status_text;
                    vertical-alignment: center;
                    color: white;
                }
            }
        }
    }
    callback request_open_file();
    callback exit();
    callback reset_view();
    callback show_settings_window();
    callback tick(bool);
    callback zoom_image(float, length, length);
    callback view_one_to_one();
    callback copy_to_clipboard();
    callback paste_from_clipboard();
}