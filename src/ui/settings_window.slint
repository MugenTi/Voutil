import { CheckBox, StandardButton } from "std-widgets.slint";

export component SettingsWindow inherits Dialog {
    title: "Preferences";
    // standard-buttons: ok; // You can use standard buttons like this

    // --- Properties for settings ---
    in-out property <bool> vsync_enabled: true;
    in-out property <bool> show_checker_background: false;

    // --- Callbacks to notify Rust of changes ---
    callback vsync_changed(bool);
    callback show_checker_background_changed(bool);


    VerticalLayout {
        padding: 10px;
        spacing: 10px;

        CheckBox {
            text: "Enable V-Sync";
            checked: root.vsync_enabled;
            toggled => {
                root.vsync_changed(self.checked);
            }
        }
        
        CheckBox {
            text: "Show checker background";
            checked: root.show_checker_background;
            toggled => {
                root.show_checker_background_changed(self.checked);
            }
        }
    }
}