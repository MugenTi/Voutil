[Desktop Entry]
Name=Voutil
Comment=A no-nonsense hardware-accelerated image viewer
GenericName=Image Viewer
Keywords=image viewer;graphics;
Exec=voutil %U
Icon=voutil
Terminal=false
Categories=Graphics;
Type=Application
MimeType=image/bmp;image/gif;image/vnd.microsoft.icon;image/jpeg;image/png;image/x-tga;image/avif;image/tiff;image/webp;image/x-exr;image/heic;image/x-qoi;image/x-portable-pixmap;
